# ── Application ─────────────────────────────────────────────────────────────
PORT=8080
ENVIRONMENT=development
RUST_LOG=info

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
DATABASE_URL=postgres://caas:caas@localhost:5432/caas_api

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# ── JWT (sign access tokens issued to developers) ───────────────────────────
JWT_SECRET=change-me-at-least-32-chars-long!!

# ── Sentry ───────────────────────────────────────────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...
